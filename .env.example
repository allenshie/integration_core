# ========= 基本執行 =========
APP_TIMEZONE=Asia/Taipei
LOG_LEVEL=INFO
PIPELINE_SCHEDULE_PATH=pipeline_schedule.json
CONFIG_SUMMARY=0
PIPELINE_SUMMARY_INTERVAL_SECONDS=60

# ========= Edge 事件接收 =========
# 支援: http / mqtt
EDGE_EVENT_BACKEND=http
EDGE_EVENT_HOST=0.0.0.0
EDGE_EVENT_PORT=9000
EDGE_EVENTS_TOPIC=edge/events

# ========= Phase 廣播 =========
# 0/1；關閉後仍會判斷 phase 與執行 pipeline，但不對外廣播 phase
PHASE_BROADCAST_ENABLED=1
# 留空時跟隨 EDGE_EVENT_BACKEND
PHASE_PUBLISH_BACKEND=
PHASE_HEARTBEAT_SECONDS=600
PHASE_TOPIC=integration/phase
PHASE_HTTP_BASE_URL=
PHASE_HTTP_TIMEOUT_SECONDS=5

# ========= Matching 結果廣播 =========
# 0/1；關閉後仍會執行 MCMOT，但不對外廣播 matching 結果
MATCHING_BROADCAST_ENABLED=0
# 留空時跟隨 PHASE_PUBLISH_BACKEND
MATCHING_BROADCAST_BACKEND=
MATCHING_BROADCAST_TOPIC=integration/matching

# ========= MQTT 連線（mqtt 模式需要） =========
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_QOS=1
MQTT_RETAIN=1
MQTT_CLIENT_ID=
MQTT_ENABLED=0
MQTT_AUTH_ENABLED=0
MQTT_USERNAME=
MQTT_PASSWORD=

# ========= Pipeline 常用開關 =========
MCMOT_ENABLED=1
# 指向外部 MCMOT 專案的設定檔；integration_core 不再內建此檔
MCMOT_CONFIG_PATH=../MCMOT/configs/road_config.yaml
# 視覺化設定實際檔案（可由 global_map_vis.example.yaml 複製而來）
GLOBAL_MAP_VIS_ENABLED=0
# 啟用後請自行複製 global_map_vis.example.yaml 並填入實際路徑
GLOBAL_MAP_VIS_CONFIG_PATH=
FORMAT_TASK_ENABLED=1
MONITOR_ENDPOINT=http://localhost:9400
INTEGRATION_MONITOR_SERVICE_NAME=integration-daemon

# ========= 插件覆寫（按需設定） =========
PHASE_ENGINE_CLASS=
SCHEDULER_ENGINE_CLASS=
INGESTION_ENGINE_CLASS=
RULES_ENGINE_CLASS=
EVENT_DISPATCH_ENGINE_CLASS=
PHASE_CHANGE_ENGINE_CLASS=

# ========= 健康檢查（K8s Probe，可選） =========
INTEGRATION_HEALTH_SERVER_ENABLED=0
INTEGRATION_HEALTH_SERVER_HOST=0.0.0.0
INTEGRATION_HEALTH_SERVER_PORT=8081
INTEGRATION_HEALTH_LIVENESS_TIMEOUT_SECONDS=30
INTEGRATION_HEALTH_READINESS_TIMEOUT_SECONDS=30
INTEGRATION_HEALTH_STARTUP_GRACE_SECONDS=10

# ========= 相容舊鍵名（過渡期，不建議新增使用） =========
# EDGE_EVENTS_MQTT_TOPIC=edge/events
# PHASE_MQTT_TOPIC=integration/phase
